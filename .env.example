# Salto environment variables.
# Copy to .env and adjust; docker-compose.yml reads it automatically.
# Never commit your real .env.

# Host port the app is published on (maps to port 3000 inside the container).
# Point your reverse proxy (e.g. Nginx Proxy Manager) at this port.
SALTO_PORT=3000

# Port the server listens on *inside* the container. Only relevant when
# running the server outside Docker (npm start); the compose file keeps
# the container-internal port at 3000.
#PORT=3000

# Directory where the SQLite database is stored. The compose file sets this
# to /data and mounts a named volume there so data survives updates.
#DATA_DIR=/data

# Secret used to sign session cookies. Required once first-run admin setup
# and login ship (Phase 1 authentication). Generate with:
#   openssl rand -hex 32
#SESSION_SECRET=
